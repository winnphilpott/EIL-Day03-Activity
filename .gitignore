.Rhistory
.RData
.Rproj.user/
*.Rproj

# renv
renv/library/
renv/staging/

# Output files (regenerated by scripts — commit selectively if desired)
output/figures/*
output/tables/*
output/statistics/*
!output/figures/.gitkeep
!output/tables/.gitkeep
!output/statistics/.gitkeep

# Large / sensitive raw data (add exceptions below as needed)
# data/raw/*
# !data/raw/.gitkeep

# macOS
.DS_Store

# Python / Jupyter (if any exploratory notebooks)
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Credentials and secrets
.env
*.pem
*.key
secrets/
